{% extends '@MauticCore/Default/content.html.twig' %}

{% block mauticContent %}mautomic_crm_task_queue{% endblock %}

{% block headerTitle %}{{ item.name }}{% endblock %}

{% block preHeader %}
    {{- include('@MauticCore/Helper/page_actions.html.twig', {
        'item': item,
        'templateButtons': {
            'close': securityIsGranted('mautomic_crm:tasks:view'),
        },
        'routeBase': 'mautomic_crm_task_queue',
        'targetLabel': 'mautomic_crm.task_queues'|trans,
    }) -}}
{% endblock %}

{% block actions %}
    {{- include('@MauticCore/Helper/page_actions.html.twig', {
        'item': item,
        'templateButtons': {
            'edit': securityHasEntityAccess(permissions['mautomic_crm:tasks:editown'], permissions['mautomic_crm:tasks:editother'], item.createdBy),
            'delete': securityHasEntityAccess(permissions['mautomic_crm:tasks:deleteown'], permissions['mautomic_crm:tasks:deleteother'], item.createdBy),
        },
        'routeBase': 'mautic_mautomic_crm_task_queue',
        'langVar': 'mautomic_crm.task_queue',
        'customButtons': [
            {
                'attr': {
                    'data-toggle': 'ajax',
                    'href': path('mautic_mautomic_crm_task_queue_action', {'objectAction': 'focus', 'objectId': item.id}),
                    'class': 'btn btn-primary',
                },
                'btnText': 'mautomic_crm.task_queue.focus_mode'|trans,
                'iconClass': 'ri-focus-3-line',
            },
        ],
    }) -}}
{% endblock %}

{% block content %}
  <div class="box-layout">
      <div class="col-md-9 height-auto pa-md">
          <table class="table table-hover mb-0">
              <tbody>
              {{ include('@MauticCore/Helper/details.html.twig', {'entity': item}) }}
              <tr>
                  <td width="20%"><span class="fw-b">{{ 'mautomic_crm.task_queue.sort_order'|trans }}</span></td>
                  <td>{{ ('mautomic_crm.task_queue.sort.' ~ item.sortOrder)|trans }}</td>
              </tr>
              <tr>
                  <td><span class="fw-b">{{ 'mautomic_crm.task_queue.is_shared'|trans }}</span></td>
                  <td>{{ item.shared ? 'mautic.core.yes'|trans : 'mautic.core.no'|trans }}</td>
              </tr>
              <tr>
                  <td><span class="fw-b">{{ 'mautomic_crm.task_queue.owner'|trans }}</span></td>
                  <td>{% if item.owner %}{{ item.owner.name }}{% else %}-{% endif %}</td>
              </tr>
              </tbody>
          </table>

          <h4 class="mt-lg mb-sm">{{ 'mautomic_crm.task_queue.items'|trans }}</h4>
          {% if item.items|length > 0 %}
              <table class="table table-hover">
                  <thead>
                  <tr>
                      <th>#</th>
                      <th>{{ 'mautomic_crm.task.title'|trans }}</th>
                      <th>{{ 'mautomic_crm.task.due_date'|trans }}</th>
                      <th>{{ 'mautomic_crm.task.priority'|trans }}</th>
                      <th>{{ 'mautomic_crm.task.status'|trans }}</th>
                      <th>{{ 'mautomic_crm.task_queue.item_status'|trans }}</th>
                  </tr>
                  </thead>
                  <tbody>
                  {% for queueItem in item.items %}
                      <tr class="{{ queueItem.status == 'completed' ? 'text-muted' : '' }}{{ queueItem.status == 'skipped' ? 'text-warning' : '' }}">
                          <td>{{ queueItem.itemOrder }}</td>
                          <td>
                              {% if queueItem.task %}
                                  <a data-toggle="ajax" href="{{ path('mautic_mautomic_crm_task_action', {'objectAction': 'view', 'objectId': queueItem.task.id}) }}">
                                      {{ queueItem.task.title }}
                                  </a>
                              {% endif %}
                          </td>
                          <td>{% if queueItem.task and queueItem.task.dueDate %}{{ queueItem.task.dueDate|date('Y-m-d H:i') }}{% else %}-{% endif %}</td>
                          <td>{% if queueItem.task %}{{ ('mautomic_crm.task.priority.' ~ queueItem.task.priority)|trans }}{% endif %}</td>
                          <td>{% if queueItem.task %}{{ ('mautomic_crm.task.status.' ~ queueItem.task.status)|trans }}{% endif %}</td>
                          <td>
                              <span class="label {{ queueItem.status == 'completed' ? 'label-success' : (queueItem.status == 'skipped' ? 'label-warning' : 'label-default') }}">
                                  {{ ('mautomic_crm.task_queue.status.' ~ queueItem.status)|trans }}
                              </span>
                          </td>
                      </tr>
                  {% endfor %}
                  </tbody>
              </table>
          {% else %}
              <p class="text-muted">{{ 'mautomic_crm.task_queue.no_items'|trans }}</p>
          {% endif %}
      </div>

      <div class="col-md-3 bdr-l height-auto">
          <div class="panel shd-none bdr-rds-0 bdr-w-0 mb-0">
              {{ include('@MauticCore/Helper/recentactivity.html.twig', {'logs': logs}) }}
          </div>
      </div>
  </div>
{% endblock %}
