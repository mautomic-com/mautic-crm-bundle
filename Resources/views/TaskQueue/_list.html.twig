{# Task Queue inner list #}
{% if items|length > 0 %}
    <div class="table-responsive page-list">
        <table class="table table-hover task-queue-list" id="taskQueueTable">
            <thead>
            <tr>
                {{ include('@MauticCore/Helper/tableheader.html.twig', {
                    'checkall': 'true',
                    'target': '#taskQueueTable',
                }) }}

                {{ include('@MauticCore/Helper/tableheader.html.twig', {
                    'sessionVar': 'mautomic_crm_task_queue',
                    'orderBy': 'tq.name',
                    'text': 'mautomic_crm.task_queue.name',
                    'default': true,
                }) }}

                {{ include('@MauticCore/Helper/tableheader.html.twig', {
                    'sessionVar': 'mautomic_crm_task_queue',
                    'text': 'mautomic_crm.task_queue.sort_order',
                    'class': 'visible-md visible-lg',
                }) }}

                {{ include('@MauticCore/Helper/tableheader.html.twig', {
                    'sessionVar': 'mautomic_crm_task_queue',
                    'text': 'mautomic_crm.task_queue.is_shared',
                    'class': 'visible-md visible-lg',
                }) }}

                {{ include('@MauticCore/Helper/tableheader.html.twig', {
                    'sessionVar': 'mautomic_crm_task_queue',
                    'orderBy': 'tq.id',
                    'text': 'mautic.core.id',
                    'class': 'visible-md visible-lg',
                }) }}
            </tr>
            </thead>
            <tbody>
            {% for item in items %}
                <tr>
                    <td>
                        {{ include('@MauticCore/Helper/list_actions.html.twig', {
                            'item': item,
                            'templateButtons': {
                                'edit': securityHasEntityAccess(permissions['mautomic_crm:tasks:editown'], permissions['mautomic_crm:tasks:editother'], item.createdBy),
                                'delete': securityHasEntityAccess(permissions['mautomic_crm:tasks:deleteown'], permissions['mautomic_crm:tasks:deleteother'], item.createdBy),
                            },
                            'routeBase': 'mautic_mautomic_crm_task_queue',
                            'customButtons': [
                                {
                                    'attr': {
                                        'data-toggle': 'ajax',
                                        'href': path('mautic_mautomic_crm_task_queue_action', {'objectAction': 'focus', 'objectId': item.id}),
                                    },
                                    'btnText': 'mautomic_crm.task_queue.focus_mode'|trans,
                                    'iconClass': 'ri-focus-3-line',
                                },
                            ],
                        }) }}
                    </td>
                    <td>
                        <a data-toggle="ajax" href="{{ path('mautic_mautomic_crm_task_queue_action', {'objectId': item.id, 'objectAction': 'view'}) }}">
                            {{ item.name }}
                        </a>
                    </td>
                    <td class="visible-md visible-lg">{{ ('mautomic_crm.task_queue.sort.' ~ item.sortOrder)|trans }}</td>
                    <td class="visible-md visible-lg">
                        {% if item.shared %}
                            <span class="label label-success">{{ 'mautic.core.yes'|trans }}</span>
                        {% else %}
                            <span class="label label-default">{{ 'mautic.core.no'|trans }}</span>
                        {% endif %}
                    </td>
                    <td class="visible-md visible-lg">{{ item.id }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="panel-footer">
        {{ include('@MauticCore/Helper/pagination.html.twig', {
            'totalItems': items|length,
            'page': page,
            'limit': limit,
            'baseUrl': path('mautic_mautomic_crm_task_queue_index'),
            'sessionVar': 'mautomic_crm_task_queue',
        }) }}
    </div>
{% else %}
    {{ include('@MauticCore/Helper/noresults.html.twig', {'tip': 'mautomic_crm.task_queue.noresults.tip'}) }}
{% endif %}
