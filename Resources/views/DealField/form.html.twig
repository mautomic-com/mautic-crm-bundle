{% extends '@MauticCore/Default/content.html.twig' %}

{% block mauticContent %}mautomic_crm_deal_field{% endblock %}

{% block headerTitle %}
  {% if entity.id %}
    {{ 'mautomic_crm.deal_field.edit'|trans({'%name%': entity.label|trans}) }}
  {% else %}
    {{ 'mautomic_crm.deal_field.new'|trans }}
  {% endif %}
{% endblock %}

{% block content %}
  {{ form_start(form) }}
    <div class="box-layout">
        <div class="col-md-9 height-auto bdr-r pa-md">
            <div class="row">
                <div class="col-md-6">{{ form_row(form.label) }}</div>
                <div class="col-md-6">{{ form_row(form.alias) }}</div>
            </div>
            <div class="row">
                <div class="col-md-4">{{ form_row(form.type) }}</div>
                <div class="col-md-4">{{ form_row(form.fieldGroup) }}</div>
                <div class="col-md-4">{{ form_row(form.fieldOrder) }}</div>
            </div>
            <div class="row">
                <div class="col-md-12">{{ form_row(form.properties) }}</div>
            </div>
        </div>
        <div class="col-md-3 height-auto">
            <div class="pr-lg pl-lg pt-md pb-md">
                {{ form_row(form.isPublished) }}
                {{ form_row(form.isRequired) }}
            </div>
        </div>
    </div>
  {{ form_end(form) }}
{% endblock %}
