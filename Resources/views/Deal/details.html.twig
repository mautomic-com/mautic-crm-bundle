{% extends '@MauticCore/Default/content.html.twig' %}

{% block mauticContent %}mautomic_crm_deal{% endblock %}

{% block headerTitle %}{{ item.name }}{% endblock %}

{% block publishStatus %}
    {{- include('@MauticCore/Helper/publishstatus_badge.html.twig', {'entity' : item}) -}}
{% endblock %}

{% block preHeader %}
    {{- include('@MauticCore/Helper/page_actions.html.twig', {
        'item': item,
        'templateButtons': {
            'close': securityIsGranted('mautomic_crm:deals:view'),
        },
        'routeBase': 'mautomic_crm_deal',
        'targetLabel': 'mautomic_crm.deal.list'|trans,
    }) -}}
{% endblock %}

{% block actions %}
    {{- include('@MauticCore/Helper/page_actions.html.twig', {
        'item': item,
        'templateButtons': {
            'edit': securityHasEntityAccess(permissions['mautomic_crm:deals:editown'], permissions['mautomic_crm:deals:editother'], item.createdBy),
            'clone': permissions['mautomic_crm:deals:create'],
            'delete': securityHasEntityAccess(permissions['mautomic_crm:deals:deleteown'], permissions['mautomic_crm:deals:deleteother'], item.createdBy),
        },
        'routeBase': 'mautic_mautomic_crm_deal',
        'langVar': 'mautomic_crm.deal',
    }) -}}
{% endblock %}

{% block content %}
  <div class="box-layout">
      <div class="col-md-9 height-auto">
          <div>
              {% include '@MauticCore/Helper/description--expanded.html.twig' with {'description': item.description} %}

              <div class="collapse pr-md pl-md" id="deal-details">
                  <div class="pr-md pl-md pb-md">
                      <div class="panel shd-none mb-0">
                          <table class="table table-hover mb-0" data-view-table data-entity-id="{{ item.id }}">
                              <tbody>
                              {{ include('@MauticCore/Helper/details.html.twig', {'entity': item}) }}
                              <tr>
                                  <td width="20%"><span class="fw-b">{{ 'mautomic_crm.deal.amount'|trans }}</span></td>
                                  <td>{% if item.amount %}{{ item.amount }} {{ item.currency }}{% else %}-{% endif %}</td>
                              </tr>
                              <tr>
                                  <td width="20%"><span class="fw-b">{{ 'mautomic_crm.deal.pipeline'|trans }}</span></td>
                                  <td>{% if item.pipeline %}{{ item.pipeline.name }}{% else %}-{% endif %}</td>
                              </tr>
                              <tr>
                                  <td width="20%"><span class="fw-b">{{ 'mautomic_crm.deal.stage'|trans }}</span></td>
                                  <td>
                                      {% if item.stage %}
                                          {{ item.stage.name }}
                                          {% if item.stage.type == 'won' %}
                                              <span class="label label-success">{{ 'mautomic_crm.deal.stage.won'|trans }}</span>
                                          {% elseif item.stage.type == 'lost' %}
                                              <span class="label label-danger">{{ 'mautomic_crm.deal.stage.lost'|trans }}</span>
                                          {% endif %}
                                      {% else %}-{% endif %}
                                  </td>
                              </tr>
                              <tr>
                                  <td width="20%"><span class="fw-b">{{ 'mautomic_crm.deal.close_date'|trans }}</span></td>
                                  <td>{% if item.closeDate %}{{ item.closeDate|date('Y-m-d') }}{% else %}-{% endif %}</td>
                              </tr>
                              <tr>
                                  <td width="20%"><span class="fw-b">{{ 'mautomic_crm.deal.owner'|trans }}</span></td>
                                  <td>{% if item.owner %}{{ item.owner.name }}{% else %}-{% endif %}</td>
                              </tr>
                              <tr>
                                  <td width="20%"><span class="fw-b">{{ 'mautomic_crm.deal.contact'|trans }}</span></td>
                                  <td>{% if item.contact %}
                                      <a data-toggle="ajax" href="{{ path('mautic_contact_action', {'objectAction': 'view', 'objectId': item.contact.id}) }}">
                                          {{ item.contact.name }}
                                      </a>
                                  {% else %}-{% endif %}</td>
                              </tr>
                              <tr>
                                  <td width="20%"><span class="fw-b">{{ 'mautomic_crm.deal.company'|trans }}</span></td>
                                  <td>{% if item.company %}
                                      <a data-toggle="ajax" href="{{ path('mautic_company_action', {'objectAction': 'view', 'objectId': item.company.id}) }}">
                                          {{ item.company.name }}
                                      </a>
                                  {% else %}-{% endif %}</td>
                              </tr>
                              </tbody>
                          </table>
                      </div>
                  </div>
              </div>
          </div>

          <div>
              <div class="hr-expand nm">
                  <span data-toggle="tooltip" title="{{ 'mautic.core.details'|trans }}">
                      <a href="javascript:void(0)" class="arrow text-secondary collapsed" data-toggle="collapse" data-target="#deal-details"><span class="caret"></span>
                        {{ 'mautic.core.details'|trans }}
                      </a>
                  </span>
              </div>
          </div>

          {% if pipelineStages is defined and pipelineStages|length > 0 %}
              <div class="pa-md">
                  <div class="btn-group btn-group-sm" role="group" style="display: flex; flex-wrap: wrap; gap: 2px;">
                      {% set canEdit = securityHasEntityAccess(permissions['mautomic_crm:deals:editown'], permissions['mautomic_crm:deals:editother'], item.createdBy) %}
                      {% for stage in pipelineStages %}
                          {% set isCurrent = item.stage and item.stage.id == stage.id %}
                          {% if canEdit and not isCurrent %}
                              <form method="post" action="{{ path('mautic_mautomic_crm_deal_stage_change', {'objectId': item.id}) }}" style="display: inline;">
                                  <input type="hidden" name="stageId" value="{{ stage.id }}">
                                  <button type="submit" class="btn {% if stage.type == 'won' %}btn-success{% elseif stage.type == 'lost' %}btn-danger{% else %}btn-default{% endif %}">
                                      {{ stage.name }}
                                  </button>
                              </form>
                          {% else %}
                              <span class="btn {% if isCurrent %}btn-primary{% elseif stage.type == 'won' %}btn-success{% elseif stage.type == 'lost' %}btn-danger{% else %}btn-default{% endif %}{% if not canEdit %} disabled{% endif %}"{% if isCurrent %} title="{{ 'mautomic_crm.deal.stage.current'|trans }}"{% endif %}>
                                  {{ stage.name }}{% if isCurrent %} &#10003;{% endif %}
                              </span>
                          {% endif %}
                      {% endfor %}
                  </div>
              </div>
          {% endif %}

          <div class="pa-md">
              <h4>{{ 'mautomic_crm.deal.tasks'|trans }}</h4>
              {% if tasks is defined and tasks|length > 0 %}
                  <table class="table table-hover">
                      <thead>
                          <tr>
                              <th>{{ 'mautomic_crm.task.title'|trans }}</th>
                              <th>{{ 'mautomic_crm.task.status'|trans }}</th>
                              <th>{{ 'mautomic_crm.task.priority'|trans }}</th>
                              <th>{{ 'mautomic_crm.task.due_date'|trans }}</th>
                              <th>{{ 'mautomic_crm.task.owner'|trans }}</th>
                          </tr>
                      </thead>
                      <tbody>
                          {% for task in tasks %}
                              {% set isOverdue = task.dueDate is not null and task.dueDate < date() and task.status != 'completed' %}
                              <tr{% if isOverdue %} class="text-danger"{% endif %}>
                                  <td>
                                      <a data-toggle="ajax" href="{{ path('mautic_mautomic_crm_task_action', {'objectAction': 'view', 'objectId': task.id}) }}">
                                          {{ task.title }}
                                      </a>
                                      {% if isOverdue %} <span class="label label-danger">{{ 'mautomic_crm.task.overdue'|trans }}</span>{% endif %}
                                  </td>
                                  <td>{{ ('mautomic_crm.task.status.' ~ task.status)|trans }}</td>
                                  <td>{{ ('mautomic_crm.task.priority.' ~ task.priority)|trans }}</td>
                                  <td>{% if task.dueDate %}{{ task.dueDate|date('Y-m-d H:i') }}{% else %}-{% endif %}</td>
                                  <td>{% if task.owner %}{{ task.owner.name }}{% else %}-{% endif %}</td>
                              </tr>
                          {% endfor %}
                      </tbody>
                  </table>
              {% else %}
                  <div class="alert alert-info">
                      {{ 'mautomic_crm.deal.tasks.empty'|trans }}
                  </div>
              {% endif %}
          </div>

          <div class="pa-md">
              <h4>
                  {{ 'mautomic_crm.deal.notes'|trans }}
                  <a class="btn btn-primary btn-xs pull-right" href="{{ path('mautic_mautomic_crm_note_action', {'objectAction': 'new', 'dealId': item.id}) }}">
                      <i class="ri-add-line"></i> {{ 'mautomic_crm.note.add'|trans }}
                  </a>
              </h4>
              {% if notes is defined and notes|length > 0 %}
                  <div class="mt-sm">
                      {% for note in notes %}
                          {% set noteTypeIcons = {
                              'general': 'ri-chat-1-line',
                              'call': 'ri-phone-line',
                              'meeting': 'ri-team-line',
                              'email': 'ri-mail-line'
                          } %}
                          <div class="panel panel-default mb-sm">
                              <div class="panel-body">
                                  <div class="pull-right">
                                      <a class="btn btn-default btn-xs" href="{{ path('mautic_mautomic_crm_note_action', {'objectAction': 'edit', 'objectId': note.id, 'dealId': item.id}) }}">
                                          <i class="ri-pencil-line"></i>
                                      </a>
                                      <a class="btn btn-danger btn-xs" href="{{ path('mautic_mautomic_crm_note_action', {'objectAction': 'delete', 'objectId': note.id, 'dealId': item.id}) }}" data-toggle="confirmation" data-message="{{ 'mautomic_crm.note.confirmdelete'|trans }}">
                                          <i class="ri-delete-bin-line"></i>
                                      </a>
                                  </div>
                                  <div>
                                      <i class="{{ noteTypeIcons[note.type] ?? 'ri-chat-1-line' }} note-type-icon"></i>
                                      <strong>{{ ('mautomic_crm.note.type.' ~ note.type)|trans }}</strong>
                                      <span class="text-muted ml-sm">
                                          {% if note.createdByUser %}{{ note.createdByUser }}{% endif %}
                                          {% if note.dateAdded %} &middot; {{ note.dateAdded|date('Y-m-d H:i') }}{% endif %}
                                      </span>
                                  </div>
                                  <div class="mt-xs">{{ note.text|nl2br }}</div>
                              </div>
                          </div>
                      {% endfor %}
                  </div>
              {% else %}
                  <div class="alert alert-info">
                      {{ 'mautomic_crm.deal.notes.empty'|trans }}
                  </div>
              {% endif %}
          </div>
      </div>

      <div class="col-md-3 bdr-l height-auto">
          <div class="panel shd-none bdr-rds-0 bdr-w-0 mb-0">
              {{ include('@MauticCore/Helper/recentactivity.html.twig', {'logs': logs}) }}
          </div>
      </div>
  </div>
{% endblock %}
